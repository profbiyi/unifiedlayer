# Application Configuration
APP_NAME=Data Platform
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=*

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql://dataplatform:dataplatform_pass@localhost:5432/dataplatform
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# Docker PostgreSQL (used by docker-compose)
POSTGRES_USER=dataplatform
POSTGRES_PASSWORD=dataplatform_pass
POSTGRES_DB=dataplatform

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# AWS Credentials
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket

# Azure Credentials (Optional)
AZURE_STORAGE_CONNECTION_STRING=your-azure-connection-string
AZURE_STORAGE_CONTAINER=your-container-name

# GCP Credentials (Optional)
GCP_PROJECT_ID=your-gcp-project-id
GCP_CREDENTIALS_PATH=/path/to/credentials.json
GCS_BUCKET=your-gcs-bucket

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# Prefect
PREFECT_API_URL=http://localhost:4200/api
PREFECT_WORKSPACE=default
USE_PREFECT_WORKER=false  # Set to true to use Prefect worker (requires deployment)

# dlt Configuration
DLT_PROJECT_DIR=/app/dlt_data
DLT_DATA_DIR=/app/dlt_data
DLT_PIPELINE_DIR=/app/dlt_pipelines

# M-Pesa Connector
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_ENVIRONMENT=sandbox
MPESA_PASSKEY=your-mpesa-passkey
MPESA_SHORTCODE=your-mpesa-shortcode

# WhatsApp Business Connector
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-app-secret

# PostgreSQL Source (for data extraction)
POSTGRES_SOURCE_HOST=source-postgres-host
POSTGRES_SOURCE_PORT=5432
POSTGRES_SOURCE_DATABASE=source_database
POSTGRES_SOURCE_USER=source_user
POSTGRES_SOURCE_PASSWORD=source_password
POSTGRES_SOURCE_SCHEMA=public

# MySQL Source (for data extraction)
MYSQL_SOURCE_HOST=source-mysql-host
MYSQL_SOURCE_PORT=3306
MYSQL_SOURCE_DATABASE=source_database
MYSQL_SOURCE_USER=source_user
MYSQL_SOURCE_PASSWORD=source_password

# Monitoring & Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM_EMAIL=noreply@dataplatform.com
SMTP_USE_TLS=true

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#data-platform-alerts

# Trino/Presto
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_CATALOG=duckdb
TRINO_SCHEMA=main

# Data Quality
DATA_QUALITY_ENABLED=true
DATA_QUALITY_THRESHOLD=0.95

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# Encryption
ENCRYPTION_KEY=  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Frontend URL (for email links, OAuth callbacks)
FRONTEND_URL=http://localhost:3000

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Paystack Billing (Africa - NGN, KES, GHS)
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_WEBHOOK_SECRET=

# Flutterwave
FLUTTERWAVE_WEBHOOK_SECRET=

# GoCardless (UK Direct Debit)
GOCARDLESS_WEBHOOK_SECRET=

# Xero (OAuth2)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# TrueLayer / Open Banking (OAuth2)
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=

# HMRC Making Tax Digital (OAuth2)
HMRC_CLIENT_ID=
HMRC_CLIENT_SECRET=

# Feature Flags
USE_PREFECT_WORKER=false  # Enable Prefect worker execution (false = direct execution)
